[Unit]
Description=GLM-4.7-Flash Reverse SSH Tunnel (autossh)
After=network-online.target
Wants=network-online.target
PartOf=glm_4.7_flash.service
StartLimitIntervalSec=0

[Service]
Type=simple
ExecStart=/bin/bash /home/murphy/local-deployment/glm_4.7_flash_tunnel.sh
WorkingDirectory=/home/murphy/local-deployment
Restart=always
RestartSec=3
Environment=AUTOSSH_GATETIME=0
Environment=AUTOSSH_POLL=30

[Install]
WantedBy=default.target
